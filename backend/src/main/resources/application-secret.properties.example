# ============================================================
#  외부 API 키 / 비밀값 템플릿  (개발 컨벤션 §10)
#
#  [사용법]
#  1. 이 파일을 복사해서 같은 폴더에 application-secret.properties 로 저장
#  2. 실제 값은 노션 "환경변수" 페이지에서 복사해 채운다
#  3. application-secret.properties 는 .gitignore 에 있어 커밋되지 않는다
#
#  ⚠️ 실제 키를 이 example 파일에 적지 마세요! (깃에 올라갑니다)
# ============================================================

# --- JWT (Spring / FastAPI 공용) -----------------------------
jwt.secret=

# --- 오픈뱅킹 (수연) ----------------------------------------
openbanking.client-id=
openbanking.client-secret=
openbanking.redirect-uri=

# --- 국토교통부 전월세 실거래가 (수연) ------------------------
molit.service-key=

# --- 행정안전부 법정동코드 (수연) ----------------------------
mois.service-key=

# --- 카카오 알림 (수연) --------------------------------------
kakao.rest-api-key=
kakao.redirect-uri=

# --- 금융감독원 예적금 상품 (석윤) ---------------------------
fss.api-key=

# --- 오피넷 유가정보 (호빈) ----------------------------------
opinet.api-key=

# --- 여행지 정보 (태석) --------------------------------------
serpapi.api-key=
